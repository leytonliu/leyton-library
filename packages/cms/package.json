{
  "name": "@leyton/cms",
  "version": "7.0.12",
  "type": "module",
  "description": "CMS component system for uni-app, a declarative page rendering engine based on Vue 3",
  "keywords": [
    "cms",
    "uni-app",
    "vue3",
    "miniprogram",
    "component",
    "rendering"
  ],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    "types": "./src/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.umd.cjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "build-only": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "peerDependencies": {
    "vue": "^3.3.0",
    "@dcloudio/uni-app": "^3.0.0-alpha || ^3.0.0-0"
  },
  "peerDependenciesMeta": {
    "@dcloudio/uni-app": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@types/node": "^20.14.10",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.6",
    "vitest": "^2.1.2",
    "vue": "^3.3.0",
    "vue-tsc": "^2.0.0"
  }
}
